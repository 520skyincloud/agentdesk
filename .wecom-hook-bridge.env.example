AGENT_DESK_BASE_URL=http://127.0.0.1:8083
AGENT_DESK_CHANNEL_ID=replace-with-channel-id
AGENT_DESK_BRIDGE_TOKEN=replace-with-bridge-token

WECOM_HOOK_API_URL=http://127.0.0.1:8060/
WECOM_HOOK_WS_URL=ws://127.0.0.1:8061/message/
POLL_INTERVAL_MS=3000

# Optional. Fill it only if the hook service runs multiple logged-in clients.
# WECOM_HOOK_CLIENT=1

# Optional. Fill it if own messages echo back and cannot be filtered automatically.
# WECOM_SELF_USER_ID=1688xxxx
